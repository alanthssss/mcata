{
  "name": "merge-catalyst",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync:config": "tsx src/scripts/syncYamlConfig.ts",
    "dev": "npm run sync:config && vite",
    "build": "npm run sync:config && tsc && vite build",
    "preview": "vite preview",
    "test": "npm run sync:config && vitest run",
    "test:watch": "vitest",
    "benchmark": "npm run sync:config && tsx src/scripts/runBenchmark.ts --suite baseline",
    "benchmark:long": "npm run sync:config && tsx src/scripts/runBenchmark.ts --suite long",
    "benchmark:meta": "npm run sync:config && tsx src/scripts/runMetaBenchmark.ts",
    "balance": "npm run sync:config && tsx src/scripts/runBalanceCheck.ts",
    "balance:tune": "npm run sync:config && tsx src/scripts/runAutoTuneBalance.ts",
    "runlog:analyze": "npm run sync:config && tsx src/scripts/analyzeRunLogExports.ts",
    "docs:assets": "tsx src/scripts/generateDocsAssets.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yaml": "^2.8.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^4.1.4"
  }
}
